rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * Regla Maestra de Usuario:
     * El usuario tiene acceso total y recursivo a cualquier documento dentro de su propia rama.
     * Esto permite guardar /users/{uid}/backups/latest y cualquier otra subcolección de forma segura.
     */
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Bloqueo total del resto de la base de datos por seguridad
    match /{document=**} {
      allow read, write: if false;
    }
  }
}