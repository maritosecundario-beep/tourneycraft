rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * Acceso total recursivo para el dueño del UID.
     * Permite gestionar backups, configuraciones y cualquier subcolección.
     */
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Bloqueo por defecto para el resto de la base de datos
    match /{document=**} {
      allow read, write: if false;
    }
  }
}