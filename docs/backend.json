
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user account.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "Backup": {
      "title": "Backup",
      "type": "object",
      "description": "Cloud snapshot of the user's sports universe.",
      "properties": {
        "teams": { "type": "array" },
        "players": { "type": "array" },
        "tournaments": { "type": "array" },
        "settings": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/backups/{backupId}",
        "definition": {
          "entityName": "Backup",
          "schema": { "$ref": "#/backend/entities/Backup" },
          "description": "Stores full state snapshots for cloud sync."
        }
      }
    ]
  }
}
